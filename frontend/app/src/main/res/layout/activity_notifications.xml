<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white">

    <!-- Header Customizado -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerNotifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/verde_petroleo_profundo"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back_arrow_white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="@string/voltar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/notificacoes"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerNotifications">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Alertas do App -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="Alertas do Aplicativo"
                android:textColor="@color/verde_petroleo_profundo"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchPushNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Notificações Push"
                        android:paddingVertical="8dp"
                        app:thumbTint="@color/white"
                        app:trackDecorationTint="@color/verde_petroleo_profundo" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchChatAlerts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Novas mensagens no chat"
                        android:paddingVertical="8dp"
                        app:thumbTint="@color/white"
                        app:trackDecorationTint="@color/verde_petroleo_profundo" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Marketing -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="Promoções e Novidades"
                android:textColor="@color/verde_petroleo_profundo"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchEmailPromo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="E-mails de Promoções"
                        android:paddingVertical="8dp"
                        app:thumbTint="@color/white"
                        app:trackDecorationTint="@color/verde_petroleo_profundo" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchSmsAlerts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Alertas por SMS"
                        android:paddingVertical="8dp"
                        app:thumbTint="@color/white"
                        app:trackDecorationTint="@color/verde_petroleo_profundo" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>